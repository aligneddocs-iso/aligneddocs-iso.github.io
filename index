          <div class="wz-step">
            <div class="wz-dot${i===0?' active':''}" id="wzdot${i}" onclick="jumpStep(${i})">${i+1}</div>
            ${i<secs.length-1?`<div class="wz-line" id="wzline${i}"></div>`:''}
          </div>
        `).join('')}
      </div>
      <div class="wizard-bar-track"><div class="wizard-bar-fill" id="wzbar" style="width:${100/secs.length}%"></div></div>
      <div class="wizard-label" id="wzlabel"></div>
    </div>`;

  // Build all section panels
  const sectionsHTML=secs.map((sec,si)=>`
    <div class="form-blk${si===0?' wz-active':''}" id="wzpanel${si}">
      <div class="form-blk-t">${sec.t}</div>
      <div class="form-blk-s">${sec.s}</div>
      <div class="form-grid${sec.f.every(x=>x.full)?' full':''}">
        ${sec.f.map(f=>`
          <div class="form-fld${f.full?' form-grid full':''}">
            <label class="form-lbl">
              ${f.l}${f.r?'<em>*</em>':''}
              ${TIPS[f.id]?`
                <div class="tooltip-wrap">
                  <button class="tooltip-btn" type="button">?</button>
                  <div class="tooltip-box">${TIPS[f.id][CL]||''}</div>
                </div>`:''}
            </label>
            ${f.tp==='ta'
              ?`<textarea class="form-ta" id="${f.id}" placeholder="${f.ph}" rows="3"></textarea>`
              :`<input class="form-inp" id="${f.id}" placeholder="${f.ph}" type="${f.id==='femail'?'email':'text'}">`
            }
          </div>
        `).join('')}
      </div>
      <div class="wizard-nav">
        ${si>0?`<button class="btn btn-ghost" type="button" onclick="wzPrev()">← ${CL==='de'?'Zurück':'Back'}</button>`:'<div></div>'}
        ${si<secs.length-1
          ?`<button class="btn btn-gold" type="button" onclick="wzNext()">${CL==='de'?'Weiter':'Next'} →</button>`
          :`<button class="btn btn-gold" type="button" onclick="sub()">${CL==='de'?'Prüfen & Bestellen':'Review & Order'} →</button>`
        }
      </div>
    </div>
  `).join('');

  c.innerHTML=progressHTML+sectionsHTML;
  updateWizard();
}

function updateWizard(){
  const secs=FORM[CL];
  const total=secs.length;
  // Update dots & lines
  secs.forEach((_,i)=>{
    const dot=document.getElementById('wzdot'+i);
    const line=document.getElementById('wzline'+i);
    if(dot){
      dot.classList.remove('active','done');
      if(i<wzStep) dot.classList.add('done');
      else if(i===wzStep) dot.classList.add('active');
    }
    if(line){
      line.classList.toggle('done',i<wzStep);
    }
  });
  // Update bar
  const bar=document.getElementById('wzbar');
  if(bar) bar.style.width=`${((wzStep+1)/total)*100}%`;
  // Update label
  const lbl=document.getElementById('wzlabel');
  if(lbl){
    const cur=secs[wzStep];
    lbl.innerHTML=CL==='de'
      ?`Schritt <strong>${wzStep+1} von ${total}</strong> – ${cur.t}`
      :`Step <strong>${wzStep+1} of ${total}</strong> – ${cur.t}`;
  }
}

function showPanel(idx){
  document.querySelectorAll('[id^="wzpanel"]').forEach(p=>p.classList.remove('wz-active'));
  const panel=document.getElementById('wzpanel'+idx);
  if(panel){ panel.classList.add('wz-active'); panel.scrollIntoView({behavior:'smooth',block:'start'}); }
  wzStep=idx;
  updateWizard();
}

function wzNext(){
  // Validate current step required fields
  const sec=FORM[CL][wzStep];
  let firstErr=null;
  sec.f.forEach(f=>{
    if(f.r){
      const el=document.getElementById(f.id);
      if(el&&!el.value.trim()){
        el.classList.add('field-error-highlight');
        if(!firstErr) firstErr=el;
      } else if(el){
        el.classList.remove('field-error-highlight');
      }
    }
  });
  if(firstErr){ firstErr.scrollIntoView({behavior:'smooth',block:'center'}); firstErr.focus(); return; }
  showPanel(wzStep+1);
}

function wzPrev(){ showPanel(wzStep-1); }

function jumpStep(i){
  // Only allow jumping to completed steps
  if(i<=wzStep) showPanel(i);
}

function toggleEmailVis(){
  const inp=document.getElementById('rv-email-show');
  const iconShow=document.getElementById('eye-icon-show');
  const iconHide=document.getElementById('eye-icon-hide');
  if(!inp) return;
  if(inp.type==='password'){
    inp.type='text';
    iconShow.style.display='none';
    iconHide.style.display='block';
  } else {
    inp.type='password';
    iconShow.style.display='block';
    iconHide.style.display='none';
  }
}

function sub(){
  // Validate last step required fields
  const sec=FORM[CL][wzStep];
  let firstErr=null;
  sec.f.forEach(f=>{
    if(f.r){
      const el=document.getElementById(f.id);
      if(el&&!el.value.trim()){
        el.classList.add('field-error-highlight');
        if(!firstErr) firstErr=el;
      } else if(el){
        el.classList.remove('field-error-highlight');
      }
    }
  });
  if(firstErr){ firstErr.scrollIntoView({behavior:'smooth',block:'center'}); firstErr.focus(); return; }
  buildReview();
  go('review');
}

function buildReview(){
  const secs = FORM[CL];
  const labels = {
    de:{ empty:'(keine Angabe)' },
    en:{ empty:'(not provided)' }
  };
  const empty = labels[CL].empty;

  const container = document.getElementById('review-sections');
  container.innerHTML = secs.map(sec => `
    <div class="review-blk">
      <div class="review-blk-t">${sec.t}</div>
      ${sec.f.map(f => {
        const el = document.getElementById(f.id);
        const val = el ? el.value.trim() : '';
        return `
          <div class="review-row">
            <div class="review-label">${f.l}</div>
            <div class="review-val${val ? '' : ' empty'}">${val ? val.replace(/\n/g,'<br>') : empty}</div>
          </div>`;
      }).join('')}
    </div>
  `).join('');

  // Populate email field
  const emailEl = document.getElementById('femail');
  const emailShow = document.getElementById('rv-email-show');
  if(emailEl && emailShow){
    emailShow.value = emailEl.value;
  }
  // Reset confirm field
  const confirm = document.getElementById('rv-email-confirm');
  if(confirm) { confirm.value = ''; confirm.classList.remove('err','ok'); }
  const errMsg = document.getElementById('rv-email-err');
  if(errMsg) errMsg.classList.remove('show');
  const blk = document.getElementById('email-confirm-blk');
  if(blk) blk.classList.remove('error');
}

function checkEmail(){
  const emailShow = document.getElementById('rv-email-show');
  const confirm = document.getElementById('rv-email-confirm');
  const errMsg = document.getElementById('rv-email-err');
  const blk = document.getElementById('email-confirm-blk');
  if(!confirm.value){
    confirm.classList.remove('err','ok');
    errMsg.classList.remove('show');
    blk.classList.remove('error');
    return;
  }
  const match = emailShow.value.trim().toLowerCase() === confirm.value.trim().toLowerCase();
  confirm.classList.toggle('err', !match);
  confirm.classList.toggle('ok', match);
  errMsg.classList.toggle('show', !match);
  blk.classList.toggle('error', !match);
}

function backToForm(){
  go('form');
  setTimeout(()=>showPanel(wzStep),50);
}

function finalSubmit(){
  const emailShow=document.getElementById('rv-email-show');
  const confirm=document.getElementById('rv-email-confirm');
  const errMsg=document.getElementById('rv-email-err');
  const blk=document.getElementById('email-confirm-blk');
  if(!confirm.value.trim()){confirm.classList.add('err');errMsg.classList.add('show');blk.classList.add('error');confirm.focus();return;}
  const match=emailShow.value.trim().toLowerCase()===confirm.value.trim().toLowerCase();
  if(!match){confirm.classList.add('err');errMsg.classList.add('show');blk.classList.add('error');confirm.focus();return;}
  alert(CL==='de'
    ?'✓ Vielen Dank! Ihre Bestellung ist eingegangen. Ihr ISO 9001 Qualitätshandbuch wird erstellt und an '+emailShow.value+' gesendet, sobald es bereit ist.'
    :'✓ Thank you! Your order has been received. Your ISO 9001 quality manual will be prepared and delivered to '+emailShow.value+' as soon as it is ready.'
  );
}

function initReveal(){
  const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');});},{threshold:.08});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
}

/* ── THEME TOGGLE ── */
function toggleTheme(){
  const isLight=document.documentElement.getAttribute('data-theme')==='light';
  applyTheme(isLight?'dark':'light');
  localStorage.setItem('ad-theme',isLight?'dark':'light');
}
function applyTheme(t){
  if(t==='light'){
    document.documentElement.setAttribute('data-theme','light');
    document.getElementById('theme-icon-moon').style.display='none';
    document.getElementById('theme-icon-sun').style.display='block';
    document.querySelector('meta[name="theme-color"]').setAttribute('content','#F8F6F1');
  } else {
    document.documentElement.removeAttribute('data-theme');
    document.getElementById('theme-icon-moon').style.display='block';
    document.getElementById('theme-icon-sun').style.display='none';
    document.querySelector('meta[name="theme-color"]').setAttribute('content','#080A0F');
  }
  updateThemeTip();
}
function updateThemeTip(){
  const tip=document.getElementById('theme-tip');
  if(!tip)return;
  const isLight=document.documentElement.getAttribute('data-theme')==='light';
  tip.textContent=CL==='de'
    ?(isLight?'Dark Mode':'Light Mode')
    :(isLight?'Switch to Dark Mode':'Switch to Light Mode');
}
(function(){
  const saved=localStorage.getItem('ad-theme');
  if(saved){applyTheme(saved);return;}
  if(window.matchMedia&&window.matchMedia('(prefers-color-scheme: light)').matches)applyTheme('light');
})();

/* ── EXIT INTENT ── */
let exitShown=false,exitCooldown=false;
document.addEventListener('mouseleave',e=>{
  if(e.clientY<=0&&!exitShown&&!exitCooldown){exitShown=true;document.getElementById('exit-overlay').classList.add('show');}
});
let mobileExitTimer;
function resetMobileExitTimer(){
  clearTimeout(mobileExitTimer);
  mobileExitTimer=setTimeout(()=>{
    if(!exitShown&&!exitCooldown){exitShown=true;document.getElementById('exit-overlay').classList.add('show');}
  },45000);
}
['touchstart','touchend','scroll'].forEach(ev=>document.addEventListener(ev,resetMobileExitTimer,{passive:true}));
resetMobileExitTimer();
function closeExit(){
  document.getElementById('exit-overlay').classList.remove('show');
  exitCooldown=true;setTimeout(()=>{exitCooldown=false;exitShown=false;},120000);
}
async function submitExit(){
  const name=document.getElementById('ex-name').value.trim();
  const email=document.getElementById('ex-email').value.trim();
  const msg=document.getElementById('ex-msg').value.trim();
  const err=document.getElementById('ex-err');
  if(!email||!msg){err.classList.add('show');return;}
  err.classList.remove('show');
  const btn=document.querySelector('#ex-form-wrap .btn-gold');
  if(btn){btn.style.opacity='.6';btn.style.pointerEvents='none';}
  try{
    await fetch('YOUR_N8N_CONTACT_WEBHOOK_URL',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({name,email,message:msg,source:'exit-intent',lang:CL})
    });
  }catch(e){}
  document.getElementById('ex-form-wrap').style.display='none';
  document.getElementById('ex-success-email').textContent=email;
  document.getElementById('ex-success').style.display='block';
  setTimeout(closeExit,4000);
}

/* ── SELF-CHECK + EXIT + THEME TRANSLATIONS ── */
function updateTexts(){
  // Self-check
  const sc={en:{t:'Self-Check',b:'Please review your entries above. If any field seems incomplete or unclear, we will contact you before creating your manual. You can always go back and edit.'},
             de:{t:'Selbstcheck',b:'Bitte prüfen Sie Ihre Angaben oben. Sollte ein Feld unvollständig oder unklar sein, melden wir uns vor der Erstellung Ihres Handbuchs bei Ihnen. Sie können jederzeit zurückgehen und bearbeiten.'}};
  const el_t=document.getElementById('sc-title');const el_b=document.getElementById('sc-body');
  if(el_t)el_t.textContent=sc[CL].t;if(el_b)el_b.textContent=sc[CL].b;
  // Exit popup
  const ex={en:{eye:'Questions',h:'Have a question before ordering?',sub:"Send us a message — we'll get back to you.",
               send:'Send message →',cancel:'Not now',err:'Please fill in all required fields.',
               s1:"Thank you! We'll reply to",s2:'shortly.'},
            de:{eye:'Fragen',h:'Haben Sie eine Frage vor der Bestellung?',sub:'Schreiben Sie uns — wir melden uns bei Ihnen.',
               send:'Nachricht senden →',cancel:'Nicht jetzt',err:'Bitte alle Pflichtfelder ausfüllen.',
               s1:'Vielen Dank! Wir antworten an',s2:'in Kürze.'}};
  const d=ex[CL];
  const ids={'ex-eye':'eye','ex-h':'h','ex-sub':'sub','ex-send-txt':'send','ex-cancel-txt':'cancel','ex-err-txt':'err','ex-success-txt':'s1','ex-success-txt2':'s2'};
  Object.entries(ids).forEach(([id,key])=>{const el=document.getElementById(id);if(el)el.textContent=d[key];});
  const phs={en:{n:'Your name',e:'Your email *',m:'Your question *'},de:{n:'Ihr Name',e:'Ihre E-Mail *',m:'Ihre Frage *'}};
  const p=phs[CL];
  const n=document.getElementById('ex-name');const em=document.getElementById('ex-email');const m=document.getElementById('ex-msg');
  if(n)n.placeholder=p.n;if(em)em.placeholder=p.e;if(m)m.placeholder=p.m;
  // Theme tip
  updateThemeTip();
}

