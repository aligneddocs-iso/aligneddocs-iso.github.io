let CL='en';
let formBuilt=false;
let wzStep=0;

/* ── Save/restore form values ── */
function saveFormValues(){
  const vals={};
  ['de','en'].forEach(lang=>FORM[lang].forEach(sec=>sec.f.forEach(f=>{
    const el=document.getElementById(f.id);
    if(el&&el.value) vals[f.id]=el.value;
  })));
  return vals;
}
function restoreFormValues(vals){
  if(!vals)return;
  Object.entries(vals).forEach(([id,val])=>{const el=document.getElementById(id);if(el)el.value=val;});
}

function go(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
  if(p==='faq') buildFAQ();
  if(p==='prod') buildPipe();
  if(p==='form'&&!formBuilt){buildForm();formBuilt=true;}
  setTimeout(initReveal,80);
}

function setL(l){
  const savedVals=formBuilt?saveFormValues():null;
  const savedStep=wzStep;
  CL=l;
  document.documentElement.lang=l;
  document.getElementById('ld').classList.toggle('on',l==='de');
  document.getElementById('le').classList.toggle('on',l==='en');
  applyT();buildFAQ();buildPipe();
  formBuilt=false;buildForm();formBuilt=true;
  if(savedVals)restoreFormValues(savedVals);
  showPanel(savedStep);
  updateTexts();
}

function applyT(){
  const d=T[CL];
  for(const[k,v]of Object.entries(d)){const e=document.getElementById(k);if(e)e.innerHTML=v;}
  document.querySelectorAll('.wz-back-lbl').forEach(el=>el.textContent=CL==='de'?'Zurück':'Back');
  document.querySelectorAll('.wz-next-lbl').forEach(el=>el.textContent=CL==='de'?'Weiter':'Next');
  document.querySelectorAll('.wz-submit-lbl').forEach(el=>el.textContent=CL==='de'?'Prüfen & Bestellen':'Review & Order');
  updateThemeTip();
}

function buildPipe(){
  const c=document.getElementById('pipe');if(!c)return;
  const steps=PIPE[CL];
  c.innerHTML=steps.map((s,i)=>`
    <div class="pipe-step">
      <div class="pipe-node">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" width="20" height="20"><path d="${s.ic}"/></svg>
      </div>
      <div class="pipe-tit">${s.t}</div>
      <div class="pipe-sub">${s.s.replace(/\n/g,'<br>')}</div>
    </div>
    ${i<steps.length-1?`<div class="pipe-con"><div class="con-line"><span class="con-arrow">›</span></div></div>`:''}
  `).join('');
}

function buildFAQ(){
  const c=document.getElementById('faq-list');if(!c)return;
  c.innerHTML=FAQ[CL].map((f,i)=>`
    <div class="faq-it" id="fi${i}">
      <div class="faq-q" onclick="tFAQ(${i})">
        <span>${f.q}</span>
        <div class="faq-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M7 2v10M2 7h10"/></svg></div>
      </div>
      <div class="faq-a">${f.a}</div>
    </div>
  `).join('');
}

function tFAQ(i){document.getElementById('fi'+i).classList.toggle('open');}

